<UserControl x:Class="SafeDriveBackup.Views.StatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource ContentBg}">
        <StackPanel Margin="28,28,28,28">

            <!-- ── Ransomware warning banner ─────────────────── -->
            <Border Background="#FFF3CD" CornerRadius="8" Padding="16" Margin="0,0,0,20"
                    BorderBrush="#FDCB6E" BorderThickness="1"
                    Visibility="{Binding ShowRansomwareWarning, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontWeight="Bold" FontSize="14" Text="⚠ Backup Paused — Ransomware Protection Active"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12"
                                   Text="{Binding RansomwareWarning}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Dismiss"
                            Style="{StaticResource SecondaryBtn}" VerticalAlignment="Top"
                            Command="{Binding DismissWarningCommand}"/>
                </Grid>
            </Border>

            <!-- ── Top status card ───────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status info -->
                    <StackPanel Grid.Column="0">
                        <!-- Big status badge -->
                        <Border CornerRadius="20" Padding="14,6"
                                HorizontalAlignment="Left"
                                Background="{Binding StatusColor, Converter={StaticResource StrToBrush}}">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="White" FontWeight="Bold" FontSize="15"/>
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Last backup:"
                                           Style="{StaticResource Muted}" Width="140"/>
                                <TextBlock Text="{Binding LastBackup}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Destination:"
                                           Style="{StaticResource Muted}" Width="140"/>
                                <TextBlock Text="{Binding Destination}" FontSize="13"
                                           TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Progress bar -->
                        <Border Margin="0,12,0,0"
                                Visibility="{Binding IsBackingUp, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentOperation}"
                                           Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <ProgressBar IsIndeterminate="True" Height="4"
                                             Foreground="{StaticResource AccentBlue}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Content="Backup Now"
                                Style="{StaticResource SuccessBtn}"
                                Command="{Binding BackupNowCommand}"
                                Width="130"/>
                        <Button Content="Pause"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding PauseCommand}"
                                Width="130" Margin="0,8,0,0"
                                Visibility="{Binding IsPaused, Converter={StaticResource InvBoolToVis}}"/>
                        <Button Content="Resume"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ResumeCommand}"
                                Width="130" Margin="0,8,0,0"
                                Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Last run stats ────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="Last Run" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Files copied -->
                        <Border Grid.Column="0" CornerRadius="8" Background="#EBF8F4"
                                Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding FilesCopied}" FontSize="28"
                                           FontWeight="Bold" Foreground="{StaticResource GreenOk}"/>
                                <TextBlock Text="New files copied" Style="{StaticResource Muted}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Files updated -->
                        <Border Grid.Column="1" CornerRadius="8" Background="#EBF3FB"
                                Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{Binding FilesUpdated}" FontSize="28"
                                           FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                                <TextBlock Text="Files updated" Style="{StaticResource Muted}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Files failed -->
                        <Border Grid.Column="2" CornerRadius="8" Background="#FEF0F0"
                                Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding FilesFailed}" FontSize="28"
                                           FontWeight="Bold" Foreground="{StaticResource RedError}"/>
                                <TextBlock Text="Failed" Style="{StaticResource Muted}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Protected folders ─────────────────────────── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="Protected Folders"
                               Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding Folders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" Text="{Binding SourcePath}"
                                                   Style="{StaticResource Muted}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="2" CornerRadius="10" Padding="10,3"
                                                Background="{Binding Status,
                                                    Converter={StaticResource StatusToColor}}">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="White" FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
