<UserControl x:Class="SafeDriveBackup.Views.FolderSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource ContentBg}">
        <StackPanel Margin="28,28,28,28" MaxWidth="640">

            <TextBlock Style="{StaticResource H1}" Text="Folder Selection" Margin="0,0,0,6"/>
            <TextBlock Style="{StaticResource Muted}"
                       Text="Choose which user folders SafeDrive will back up."
                       Margin="0,0,0,24"/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="User Folders" Margin="0,0,0,16"/>

                    <CheckBox Content="Desktop"   IsChecked="{Binding Desktop}"   Margin="0,6"/>
                    <CheckBox Content="Documents" IsChecked="{Binding Documents}" Margin="0,6"/>
                    <CheckBox Content="Downloads" IsChecked="{Binding Downloads}" Margin="0,6"/>
                    <CheckBox Content="Pictures"  IsChecked="{Binding Pictures}"  Margin="0,6"/>
                    <CheckBox Content="Music"     IsChecked="{Binding Music}"     Margin="0,6"/>
                    <CheckBox Content="Videos"    IsChecked="{Binding Videos}"    Margin="0,6"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button Content="Save Changes"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding SaveCommand}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource GreenOk}"
                           VerticalAlignment="Center" Margin="16,0,0,0" FontSize="13"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
            </StackPanel>

            <Border Style="{StaticResource Card}" Margin="0,20,0,0" Background="#EBF3FB">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"
                               Text="Note" Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               Text="Changes take effect on the next backup run. De-selecting a folder stops future backups but does not remove existing backup files."/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
