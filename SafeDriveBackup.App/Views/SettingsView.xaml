<UserControl x:Class="SafeDriveBackup.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource ContentBg}">
        <StackPanel Margin="28,28,28,28" MaxWidth="640">

            <TextBlock Style="{StaticResource H1}" Text="Settings" Margin="0,0,0,6"/>
            <TextBlock Style="{StaticResource Muted}"
                       Text="Configure backup behaviour and retention."
                       Margin="0,0,0,24"/>

            <!-- System -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="System" Margin="0,0,0,12"/>
                    <CheckBox Content="Start SafeDrive Backup when Windows starts"
                              IsChecked="{Binding StartWithWindows}" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Retention -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="Retention" Margin="0,0,0,12"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Keep latest versions per file:"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding KeepVersions, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Keep deleted files for (days):"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding KeepDeletedDays, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Periodic full scan interval (hours):"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding PeriodicScanHours, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Ransomware protection -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="Ransomware Protection"
                               Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="Automatically pause backup if too many files change in a short time."/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Pause if more than N files change:"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding RansomwareThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="within minutes:"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding RansomwareWindowMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Retry -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="Retry Behaviour" Margin="0,0,0,12"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Retry delay for locked files (seconds):"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding RetryDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Maximum retry attempts:"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding MaxRetryAttempts, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Save Settings"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Reset to Defaults"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ResetCommand}"
                        Margin="12,0,0,0"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource GreenOk}"
                       FontSize="13" Margin="0,12,0,0"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
