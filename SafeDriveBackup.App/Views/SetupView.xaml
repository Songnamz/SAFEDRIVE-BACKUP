<UserControl x:Class="SafeDriveBackup.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <Grid Background="{StaticResource ContentBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource AccentBlue}" Padding="40,30">
            <StackPanel>
                <TextBlock Text="SafeDrive Backup" FontSize="28" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Simple, safe backup for your important folders."
                           Foreground="#BFD9EF" FontSize="14" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Steps -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="560" Margin="60,40,60,20" HorizontalAlignment="Center">

                <!-- Step indicator -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Ellipse Width="32" Height="32" Fill="{StaticResource AccentBlue}"/>
                    <TextBlock VerticalAlignment="Center" Margin="6,0,0,0"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               Text="{Binding Step, StringFormat='Step {0} of 3'}"/>
                </StackPanel>

                <!-- ── Step 1: Welcome ─────────────────── -->
                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource H1}" Text="Welcome to SafeDrive Backup"/>
                    <TextBlock Margin="0,12,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}" FontSize="13"
                               Text="SafeDrive Backup keeps your important folders safe by copying them to an external drive or network location — automatically, in the background."/>

                    <Border Style="{StaticResource Card}" Margin="0,24,0,0" Padding="16">
                        <StackPanel>
                            <TextBlock Style="{StaticResource H2}" Text="How it works"/>
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="13"
                                       Foreground="{StaticResource TextMuted}"
                                       Text="• Files changed in source → copied to backup&#x0a;• Files updated → old version preserved automatically&#x0a;• Files deleted from source → moved to Deleted folder (not erased)&#x0a;• No sync, no cloud — your backup drive stays human-readable"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Step 2: Folder selection ─────────── -->
                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource H1}" Text="Choose Folders to Back Up"/>
                    <TextBlock Margin="0,8,0,16" Foreground="{StaticResource TextMuted}" FontSize="13"
                               Text="Select which user folders you want to protect."/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox Content="Desktop"   IsChecked="{Binding Desktop}"/>
                            <CheckBox Content="Documents" IsChecked="{Binding Documents}"/>
                            <CheckBox Content="Downloads" IsChecked="{Binding Downloads}"/>
                            <CheckBox Content="Pictures"  IsChecked="{Binding Pictures}"/>
                            <CheckBox Content="Music"     IsChecked="{Binding Music}"/>
                            <CheckBox Content="Videos"    IsChecked="{Binding Videos}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Step 3: Destination ──────────────── -->
                <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource H1}" Text="Choose Backup Destination"/>
                    <TextBlock Margin="0,8,0,16" Foreground="{StaticResource TextMuted}" FontSize="13"
                               Text="Select where your backups will be stored. You can use an external drive or a network path."/>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Label Content="Backup destination path:"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="Browse…"
                                        Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding BrowseCommand}"/>
                            </Grid>
                            <TextBlock Margin="0,8,0,0" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Text="Tip: Use a UNC path like \\server\share\Backup for network drives."/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Navigation buttons -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0" Padding="60,16">
            <Grid>
                <Button HorizontalAlignment="Left"
                        Content="← Back"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding BackCommand}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Next →"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding NextCommand}"
                            Visibility="{Binding IsStep3, Converter={StaticResource InvBoolToVis}}"
                            Margin="0,0,0,0"/>
                    <Button Content="Start Backup ✓"
                            Style="{StaticResource SuccessBtn}"
                            Command="{Binding FinishCommand}"
                            Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
